PORT=3000
ACTION_API_KEY=troque-por-uma-chave-forte

# mock = teste imediato da Action com candidatos fictícios
# api = chama a API real/oficial do Recrutei ou middleware interno que consulta /talent/public
RECRUTEI_MODE=mock

RECRUTEI_SEARCH_URL=https://api.recrutei.com.br/talent/public/search
RECRUTEI_PROFILE_URL_TEMPLATE=https://api.recrutei.com.br/talent/public/{talentoId}/profile
RECRUTEI_RESUME_URL_TEMPLATE=https://api.recrutei.com.br/talent/public/{talentoId}/resume

RECRUTEI_AUTH_HEADER_NAME=Authorization
RECRUTEI_API_TOKEN=Bearer troque-pelo-token-seguro
